# LLM
LLM_MODEL=gemini-2.5-flash
LLM_MODEL_BACKUP=
GEMINI_API_KEY=
# OPENAI_API_KEY=
# MISTRAL_API_KEY=


# Branding (shown to visitors via prompt / widget)
PRODUCT_NAME=Our product
WELCOME_MESSAGE=Hello. How can I help you?
OFF_TOPIC_REPLY=I can only answer questions about our product.

# Optional wiki excerpt in prompt
INJECT_WIKI_IN_PROMPT=false
WIKI_MAX_CHARS=4000

# Paths (optional overrides)
# BACKOFFICE_DIR=backoffice
# VAR_DIR=var
# Perimeter file (defaults to backoffice/perimeter.json)
# PERIMETER_FILE=backoffice/perimeter.json

# Admin — protect /backoffice/* APIs and /backoffice/ + /admin/configuration.htm
# If both ADMIN_TOKEN and ADMIN_USER/PASSWORD are set, API calls need Bearer AND Basic.
# HTML pages accept either (nginx Basic + token entered once in the browser for API).
# Leave all empty only for local dev.
ADMIN_TOKEN=
ADMIN_USER=
ADMIN_PASSWORD=

# CORS (comma-separated origins for cross-origin widget)
CORS_ORIGINS=

# Client closed-session marker (do not change unless you change the widget)
# CHAT_CLOSED_SESSION_PROMPT=Closed session
